Server (e.g., as a result of radio collisions),"},{"type":"text","text":" "},{"type":"text","text":"the next received message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or when the last message of the transaction was sent 6 or"},{"type":"text","text":" "},{"type":"text","text":"more seconds earlier."}]},{"inlineContent":[{"type":"text","text":"This defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/GenericPowerLevelSetUnacknowledged/continueTransaction":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSetUnacknowledged\/continueTransaction","url":"\/documentation\/nordicmesh\/genericpowerlevelsetunacknowledged\/continuetransaction","type":"topic","abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"title":"continueTransaction"},"doc://NordicMesh/documentation/NordicMesh/GenericPowerLevelSetUnacknowledged":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSetUnacknowledged","type":"topic","url":"\/documentation\/nordicmesh\/genericpowerlevelsetunacknowledged","abstract":[],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text