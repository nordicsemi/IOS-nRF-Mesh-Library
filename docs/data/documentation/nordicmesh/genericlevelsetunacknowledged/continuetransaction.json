{"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"variants":[{"paths":["\/documentation\/nordicmesh\/genericlevelsetunacknowledged\/continuetransaction"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSetUnacknowledged\/continueTransaction","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"title":"continueTransaction","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh18TransactionMessagePAAE08continueC0Sbvp::SYNTHESIZED::s:10NordicMesh29GenericLevelSetUnacknowledgedV","extendedModule":"NordicMesh","roleHeading":"Instance Property","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSetUnacknowledged"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The messages within a transaction carry the cumulative values of","type":"text"},{"text":" ","type":"text"},{"text":"a field. In case one or more messages within a transaction are not","type":"text"},{"text":" ","type":"text"},{"text":"received by the Server (e.g., as a result of radio collisions),","type":"text"},{"text":" ","type":"text"},{"text":"the next received message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A new transaction is started when this field is set to "},{"code":"true","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or when the last message of the transaction was sent 6 or"},{"type":"text","text":" "},{"type":"text","text":"more seconds earlier."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}]}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/GenericLevelSetUnacknowledged/continueTransaction":{"type":"topic","title":"continueTransaction","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSetUnacknowledged\/continueTransaction","kind":"symbol","url":"\/documentation\/nordicmesh\/genericlevelsetunacknowledged\/continuetransaction","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/GenericLevelSetUnackno