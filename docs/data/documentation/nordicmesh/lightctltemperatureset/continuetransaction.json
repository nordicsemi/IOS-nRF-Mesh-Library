},{"type":"text","text":" "},{"type":"text","text":"the next received message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This defaults to "},{"code":"false","type":"codeVoice"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSet/continueTransaction":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSet\/continueTransaction","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctltemperatureset\/continuetransaction","title":"continueTransaction","type":"topic","abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"role":"symbol"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSet":{"kind":"symbol","identifier":"doc:\/\/NordicMe