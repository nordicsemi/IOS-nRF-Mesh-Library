{"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSet"]]},"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSet\/delay","interfaceLanguage":"swift"},"sections":[],"metadata":{"roleHeading":"Instance Property","externalID":"s:10NordicMesh22LightCTLTemperatureSetV5delays5UInt8VSgvp","title":"delay","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","role":"symbol"},"abstract":[{"text":"Message execution delay in 5 millisecond steps.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5UInt8V","text":"UInt8","kind":"typeIdentifier"},{"text":"?","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The purpose of this field is to synchronize transitions initiated","type":"text"},{"text":" ","type":"text"},{"text":"by sending the same message multiple times with a short delay.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"text":" ","type":"text"},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such message can be repeated."},{"text":" ","type":"text"},{"text":"The first message could be sent with longer ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"type":"text","text":" "},{"type":"text","text":"synchronized."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This file has to be set together with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime"},{"text":".","type":"text"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"paths":["\/documentation\/nordicmesh\/lightctltemperatureset\/delay"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSet/delay":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctltemperatureset\/delay","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSet\/delay","title":"delay","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"type":"topic","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}]},"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSet":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSet","type":"topic","url":"\/documentation\/nordicmesh\/lightctltemperatureset","abstract":[{"type":"text","text":"The Light CTL Temperature Set is an acknowledged message used to set the"},{"type":"text","text":" "},{"type":"text","text":"Light CTL Temperature state and the Light CTL Delta UV state of an Element."}],"navigatorTitle":[{"kind":"identifier","text":"LightCTLTemperatureSet"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LightCTLTemperatureSet"}],"title":"LightCTLTemperatureSet"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"title":"delay"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"}}}