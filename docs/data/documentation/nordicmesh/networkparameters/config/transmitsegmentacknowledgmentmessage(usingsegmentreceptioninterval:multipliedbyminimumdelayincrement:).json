t which segments have been"},{"type":"text","text":" "},{"type":"text","text":"received until the moment of sending the message. Upon receiving, the transmitter should retransmit"},{"type":"text","text":" "},{"text":"all missing segments.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The initial value of the timer for a given message depends on number of segments and is calculated"},{"type":"text","text":" "},{"type":"text","text":"using the following formula:"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["min(number of segment - 0.5, acknowledgment delay increment) * segment reception interval (ms)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Number of retransmissions of the Segment Acknowledgment message can be set using"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters\/Config\/retransmitSegmentAcknowledgmentMessages(exactly:timesWhenNumberOfSegmentsIsGreaterThan:)"},{"type":"text","text":"."}]},{"name":"See Also","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters\/sarReceiverSegmentIntervalStep"}]}],"style":"note"},{"name":"See Also","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters\/sarAcknowledgmentDelayIncrement","type":"reference","isActive":true}],"type":"paragraph"}],"style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/networkparameters\/config\/transmitsegmentacknowledgmentmessage(usingsegmentreceptioninterval:multipliedbyminimumdelayincrement:)"]}],"references":{"doc://NordicMesh/documentation/NordicMesh/NetworkParameters/sarAcknowledgmentDelayIncrement":{"type":"topic","title":"sarAckn