{"kind":"symbol","identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters\/allowIvIndexRecoveryOver42","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"s:10NordicMesh17NetworkParametersV26allowIvIndexRecoveryOver42Sbvp","roleHeading":"Instance Property","symbolKind":"property","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"allowIvIndexRecoveryOver42"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"title":"allowIvIndexRecoveryOver42","modules":[{"name":"NordicMesh"}]},"abstract":[{"text":"According to Bluetooth Mesh Profile 1.0.1, section 3.10.5, if the IV Index","type":"text"},{"text":" ","type":"text"},{"text":"of the mesh network increased by more than 42 since the last connection","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(which can take at least 48 weeks), the Node should be re-provisioned."},{"type":"text","text":" "},{"type":"text","text":"However, as this library can be used to provision other Nodes, it should not"},{"type":"text","text":" "},{"type":"text","text":"be blocked from sending messages to the network only because the phone wasn’t"},{"type":"text","text":" "},{"type":"text","text":"connected to the network for that time. This flag can disable this check,"},{"type":"text","text":" "},{"type":"text","text":"effectively allowing such connection."}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"allowIvIndexRecoveryOver42","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The same can be achieved by clearing the app data (uninstalling and reinstalling","type":"text"},{"text":" ","type":"text"},{"text":"the app) and importing the mesh network. With no “previous” IV Index, the","type":"text"},{"text":" ","type":"text"},{"text":"library will accept any IV Index received in the Secure Network beacon upon","type":"text"},{"text":" ","type":"text"},{"text":"connection to the GATT Proxy Node.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/networkparameters\/allowivindexrecoveryover42"]}],"references":{"doc://NordicMesh/documentation/NordicMesh/NetworkParameters/allowIvIndexRecoveryOver42":{"role":"symbol","type":"topic","title":"allowIvIndexRecoveryOver42","url":"\/documentation\/nordicmesh\/networkparameters\/allowivindexrecoveryover42","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NetworkParameters\/allowIvIndexRecoveryOver42","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"allowIvIndexRecoveryOver42"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","abstract":[{"type":"text","text":"According to Bluetooth Mesh Profile 1.0.1, section 3.10.5, if the IV Index"},{"type":"text","text":" "},{"type":"text","text":"of the mesh network increased by more than 42 since the last connection"},{"type":"text","text":" "},{"text":"(which can take at least 48 weeks), the Node should be re-provisioned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"However, as this library can be used to provision other Nodes, it should not"},{"text":" ","type":"text"},{"type":"text","text":"be blocked from sending messages to the network only because the phone wasn’t"},{"type":"text","text":" "},{"type":"text","t