{"abstract":[{"type":"text","text":"Number of Heartbeat messages remaining to be sent."}],"variants":[{"paths":["\/documentation\/nordicmesh\/configheartbeatpublicationset\/countlog"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/ConfigHeartbeatPublicationSet\/countLog"},"metadata":{"title":"countLog","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"countLog","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh29ConfigHeartbeatPublicationSetV8countLogs5UInt8Vvp","roleHeading":"Instance Property","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/ConfigHeartbeatPublicationSet"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"countLog"},{"kind":"text","text":": "},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Possible values:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"0x00 - Periodic Heartbeat messages are not published.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"0x01 - 0x11 - Number of Heartbeat messages, 2^(n-1), that remain to be sent.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0xFF - Periodic Heartbeat messages are published indefinitely."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Other values are prohibited."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The Heartbeat Publication Count Log is a representation of the Heartbeat Publication"},{"text":" ","type":"text"},{"text":"Count state value. The Heartbeat Publication Count Log and Heartbeat Publication Count","type":"text"},{"text":" ","type":"text"},{"text":"with the value 0x00 and 0x0000 are equivalent. The Heartbeat Publication Count Log","type":"text"},{"text":" ","type":"text"},{"text":"value of 0xFF is equivalent to the Heartbeat Publication count value of 0xFFFF.","type":"text"},{"text":" ","type":"text"},{"text":"The Heartbeat Publication Count Log value between 0x01 and 0x11 shall represent that","type":"text"},{"text":" ","type":"text"},{"text":"smallest integer n where 2^(n-1) is greater than or equal to the Heartbeat Publication","type":"text"},{"type":"text","text":" "},{"text":"Count value. For example, if the Heartbeat Publication Count value is 0x0579, then the","type":"text"},{"text":" ","type":"text"},{"text":"Heartbeat Publication Count Log value would be 0x0C.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/ConfigHeartbeatPublicationSet/countLog":{"type":"topic","title":"countLog","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"countLog","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"}],"abstract":[{"text":"Number of Heartbeat messages remaining to be sent.","type":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/ConfigHeartbeatPublicationSet\/countLog","kind":"symbol","url":"\/documentation\/nordicmesh\/configheartbeatpublicationset\/countlog","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/ConfigHeartbeatPublicationSet":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/configheartbeatpublicationset","navigatorTitle":[{"kind":"identifier","text":"ConfigHeartbeatPublicationSet"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/ConfigHeartbeatPublicationSet","title":"ConfigHeartbeatPublicationSet","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConfigHeartbeatPublicationSet"}],"type":"topic","abstract":[]}}}