{"variants":[{"paths":["\/documentation\/nordicmesh\/firmwaredistributionstatus\/ttl"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStatus"]]},"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStatus\/ttl","interfaceLanguage":"swift"},"sections":[],"metadata":{"symbolKind":"property","externalID":"s:10NordicMesh26FirmwareDistributionStatusV3ttls5UInt8VSgvp","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ttl"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":"?"}],"title":"ttl","modules":[{"name":"NordicMesh"}],"roleHeading":"Instance Property"},"abstract":[{"type":"text","text":"Time To Live (TTL) value used in a firmware image distribution."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ttl","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The TTL value is the maximum number of hops the message is allowed to go through."},{"type":"text","text":" "},{"type":"text","text":"Value 0 means, that messages won’t be relied and will only be processed by the Nodes"},{"type":"text","text":" "},{"type":"text","text":"that are in direct range or the connected GATT Proxy Node."}],"type":"paragraph"},{"inlineContent":[{"text":"Valid values are in the range 0…127 (","type":"text"},{"code":"0x00 - 0x7F","type":"codeVoice"},{"text":"). Value 255 (","type":"text"},{"code":"0xFF","type":"codeVoice"},{"text":") means that","type":"text"},{"text":" ","type":"text"},{"text":"the default TTL value is to be used. Other values are Prohibited.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionStatus/ttl":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ttl"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStatus\/ttl","kind":"symbol","url":"\/documentation\/nordicmesh\/firmwaredistributionstatus\/ttl","title":"ttl","type":"topic","abstract":[{"text":"Time To Live (TTL) value used in a firmware image distribution.","type":"text"}],"role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionStatus":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FirmwareDistributionStatus","kind":"identifier"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStatus","kind":"symbol","url":"\/documentation\/nordicmesh\/firmwaredistributionstatus","title":"FirmwareDistributionStatus","type":"topic","abstract":[{"type":"text","text":"The Firmware Distribution Status message is an unacknowledged message sent by"},{"type":"text","text":" "},{"type":"text","text":"a Firmware Distribution Server to report the status of a firmware image distribution."}],"role":"symbol","navigatorTitle":[{"text":"FirmwareDistributionStatus","kind"