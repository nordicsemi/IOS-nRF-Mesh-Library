{"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSet"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSet\/continueTransaction"},"sections":[],"metadata":{"roleHeading":"Instance Property","extendedModule":"NordicMesh","externalID":"s:10NordicMesh18TransactionMessagePAAE08continueC0Sbvp::SYNTHESIZED::s:10NordicMesh20GenericPowerLevelSetV","title":"continueTransaction","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","role":"symbol"},"abstract":[{"text":"Whether the message should start a new transaction.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The messages within a transaction carry the cumulative values of","type":"text"},{"text":" ","type":"text"},{"text":"a field. In case one or more messages within a transaction are not","type":"text"},{"text":" ","type":"text"},{"text":"received by the Server (e.g., as a result of radio collisions),","type":"text"},{"text":" ","type":"text"},{"text":"the next received message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or when the last message of the transaction was sent 6 or"},{"type":"text","text":" "},{"type":"text","text":"more seconds earlier."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}],"type":"paragraph"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/genericpowerlevelset\/continuetransaction"]}],"references":{"doc://NordicMesh/documentation/NordicMesh/GenericPowerLevelSet":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/genericpowerlevelset","navigatorTitle":[{"text":"GenericPowerLevelSet","kind":"identifier"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSet","title":"GenericPowerLevelSet","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GenericPowerLevelSet"}],"type":"topic","abstract":[]},"doc://NordicMesh/documentation/NordicMesh/GenericPowerLevelSet/continueTransaction":{"type":"topic","title":"continueTransaction","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"continueTransaction"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSet\/continueTransaction","kind":"symbol","url":"\/documentation\/nordicmesh\/genericpowerlevelset\