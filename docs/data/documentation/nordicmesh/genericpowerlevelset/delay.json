{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The purpose of this field is to synchronize transitions initiated","type":"text"},{"text":" ","type":"text"},{"text":"by sending the same message multiple times with a short delay.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a Node would want to send a Generic On Off Set","type":"text"},{"text":" ","type":"text"},{"text":"Unacknowledged message to a Group Address. In order to increase","type":"text"},{"text":" ","type":"text"},{"text":"changes of successful delivery, such message can be repeated.","type":"text"},{"text":" ","type":"text"},{"text":"The first message could be sent with longer ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"text":" ","type":"text"},{"text":"receive different messages, the action they take seems more","type":"text"},{"text":" ","type":"text"},{"text":"synchronized.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This file has to be set together with ","type":"text"},{"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","isActive":true},{"type":"text","text":"."}]}]}],"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericPowerLevelSet\/delay","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguag