{"abstract":[{"text":"Defining the behavior of the node.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/localnode"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LocalNode"},"metadata":{"title":"Setting up Local Node","modules":[{"name":"NordicMesh"}],"roleHeading":"Article","role":"article"},"kind":"article","seeAlsoSections":[{"anchor":"Articles","identifiers":["doc:\/\/NordicMesh\/documentation\/NordicMesh\/Usage","doc:\/\/NordicMesh\/documentation\/NordicMesh\/CreatingNetwork","doc:\/\/NordicMesh\/documentation\/NordicMesh\/ProvisioningDevices","doc:\/\/NordicMesh\/documentation\/NordicMesh\/Connecting","doc:\/\/NordicMesh\/documentation\/NordicMesh\/SendingMessages","doc:\/\/NordicMesh\/documentation\/NordicMesh\/Configuration","doc:\/\/NordicMesh\/documentation\/NordicMesh\/Exporting","doc:\/\/NordicMesh\/documentation\/NordicMesh\/DFU"],"title":"Articles","generated":true}],"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh"],["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkManager"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The mobile application using nRF Mesh library is itself a mesh node, called the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"local node"}]},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Being a node means, that it is visible to other nodes as one or more ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Elements","type":"text"}]},{"text":", each with","type":"text"},{"text":" ","type":"text"},{"text":"one or more ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Models"}]},{"text":" which support specific behavior and allow sending and receiving messages.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The library automatically supports the following models:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Configuration Server"}],"type":"emphasis"},{"text":" (required for all nodes)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Configuration Client"}],"type":"emphasis"},{"type":"text","text":" (required for configuring nodes)"}]}]},{"content":[{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Health Server"}]},{"type":"text","text":" (required for all nodes, but not implemented yet)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Health Client"}],"type":"emphasis"},{"text":" (currently not implemented)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Private Beacon Client"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Remote Provisioning Client"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"SAR Configuration Client"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"Scene Client"}]},{"type":"text","text":" (for controlling scenes)"}]}]}]},{"inlineContent":[{"text":"and may be extended to support user models: either Bluetooth SIG defined, like ","type":"text"},{"inlineContent":[{"type":"text","text":"Generic OnOff Client"}],"type":"emphasis"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or vendor models.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The elements on the ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"local node"}]},{"text":" must be configured using ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkManager\/localElements","type":"reference","isActive":true},{"text":" property.","type":"text"},{"text":" ","type":"text"},{"text":"Each model declared in this array must have a ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/ModelDelegate","type":"reference","isActive":true},{"text":" implemented, which maps the","type":"text"},{"text":" ","type":"text"},{"text":"Op Codes of supported messages to their types, and defines the behavior of the model.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a model delegate can specify that it can handle messages with an Op Code ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"0x8204","type":"text"}]},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which should be decoded to ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericOnOffStatus","type":"reference","isActive":true},{"text":" type.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a received message cannot be mapped to any message type (i.e. no local model"},{"type":"text","text":" "},{"type":"text","text":"supports the op code of received message), it will be decoded as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/UnknownMessage"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Mind, that the first Element will contain the models mentioned above.","let primaryElement = Element(name: \"Primary Element\", location: .first, ","        models: [","            \/\/ Generic OnOff Client model:","            Model(sigModelId: .genericOnOffClientModelId, ","                  delegate: GenericOnOffClientDelegate()),","            \/\/ A simple vendor model:","            Model(vendorModelId: .simpleOnOffModelId,","                  companyId: .nordicSemiconductorCompanyId,","                  delegate: SimpleOnOffClientDelegate())","        ]",")","meshNetworkManager.localElements = [primaryElement]"]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Even if your implementation does not add any models to the default set, it is required to"},{"type":"text","text":" "},{"type":"text","text":"set the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkManager\/localElements"},{"text":". It can be set to an empty array.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The model delegate is notified when a message targeting the model is received if, and only if, the model"},{"type":"text","text":" "},{"type":"text","text":"is bound to the Application Key used to encrypt the message and is subscribed to its destination"},{"type":"text","text":" "},{"type":"text","text":"address."}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkDelegate","type":"reference","isActive":true},{"type":"text","text":", set in the manager, is notified about every message"},{"type":"text","text":" "},{"type":"text","text":"received. This includes messages targeting models that are not configured to receive messages,"},{"type":"text","text":" "},{"type":"text","text":"i.e. not bound to any key, or not subscribed to the address set as destination address of the"},{"type":"text","text":" "},{"type":"text","text":"message."}],"type":"paragraph"}],"style":"tip","type":"aside","name":"Tip"},{"content":[{"inlineContent":[{"text":"See ","type":"text"},{"code":"Example\/Source\/AppDelegate.swift","type":"codeVoice"},{"text":" in “nRF Mesh” sample app for an example.","ty