nges of successful delivery, such message can be repeated."},{"type":"text","text":" "},{"type":"text","text":"The first message could be sent with longer "},{"isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"type":"text","text":" "},{"type":"text","text":"synchronized."}]},{"type":"paragraph","inlineContent":[{"text":"This file has to be set together with ","type":"text"},{"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","isActive":true},{"text":".","type":"text"}]}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightCTLSetUnacknowledged/delay":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctlsetunacknowledged\/delay","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLSetUnacknowledged\/delay","title":"delay","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"delay"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"type":"topic","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}]},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"