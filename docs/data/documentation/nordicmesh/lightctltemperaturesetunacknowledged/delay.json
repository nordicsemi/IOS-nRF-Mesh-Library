{"sections":[],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSetUnacknowledged\/delay"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"NordicMesh"}],"role":"symbol","externalID":"s:10NordicMesh36LightCTLTemperatureSetUnacknowledgedV5delays5UInt8VSgvp","title":"delay","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","text":"UInt8"},{"kind":"text","text":"?"}],"symbolKind":"property","roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSetUnacknowledged"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"delay","kind":"identifier"},{"kind":"text","text":": "},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such message can be repeated."},{"type":"text","text":" "},{"type":"text","text":"The first message could be sent with longer "},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay"},{"type":"text","text":" "},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"type":"text","text":" "},{"type":"text","text":"synchronized."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This file has to be set together with ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"reference","isActive":true},{"text":".","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/nordicmesh\/lightctltemperaturesetunacknowledged\/delay"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Message execution delay in 5 millisecond steps.","type":"text"}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSetUnacknowledged":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSetUnacknowledged","navigatorTitle":[{"text":"LightCTLTemperatureSetUnacknowledged","kind":"identifier"}],"role":"symbol","url":"\/documentation\/nordicmesh\/lightctltemperaturesetunacknowledged","abstract":[{"text":"The Light CTL Temperature Set Unacknowledged is an unacknowledged message","type":"text"},{"text":" ","type":"text"},{"text":"used to set the Light CTL Temperature state and the Light CTL Delta UV state of an Element.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightCTLTemperatureSetUnacknowledged","kind":"identifier"}],"title":"LightCTLTemperatureSetUnacknowledged","type":"topic"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/LightCTLTemperatureSetUnacknowledged/delay":{"type":"topic","title":"delay","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":"?"}],"abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLTemperatureSetUnacknowledged\/delay","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctltemperaturesetunacknowledged\/delay","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"te