{"abstract":[{"type":"text","text":"Sets new value of IV Index and IV Update flag."}],"kind":"symbol","metadata":{"extendedModule":"NordicMesh","roleHeading":"Instance Method","externalID":"s:10NordicMesh0B7NetworkC10setIvIndex_12updateActiveys6UInt32V_SbtKF","title":"setIvIndex(_:updateActive:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setIvIndex"},{"kind":"text","text":"("},{"preciseIdentifier":"s:s6UInt32V","kind":"typeIdentifier","text":"UInt32"},{"kind":"text","text":", "},{"kind":"externalParam","text":"updateActive"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setIvIndex"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"index"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s6UInt32V","text":"UInt32"},{"kind":"text","text":", "},{"kind":"externalParam","text":"updateActive"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The new value of IV Index."}],"type":"paragraph"}],"name":"index"},{"content":[{"inlineContent":[{"text":"IV Update Active flag.","type":"text"}],"type":"paragraph"}],"name":"updateActive"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method allows setting the IV Index of the mesh network when the provisioner","type":"text"},{"text":" ","type":"text"},{"text":"is not connected to the network and did not receive the Secure Network beacon,","type":"text"},{"text":" ","type":"text"},{"text":"for example to provision a Node.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Otherwise, if the local Node is connecting to the mesh network using GATT Proxy,","type":"text"},{"text":" ","type":"text"},{"text":"it will obtain the current IV Index automatically just after connection using the","type":"text"},{"text":" ","type":"text"},{"text":"Secure Network beacon, in which case calling this method is not necessary.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mind, that unless there are no Nodes in the network except the"},{"type":"text","text":" "},{"type":"text","text":"Provisioner, it is no possible to revert IV Index to smaller value"},{"type":"text","text":" "},{"type":"text","text":"(at least not using the public API). If you set too high IV Index"},{"type":"text","text":" "},{"text":"the phone will not be able to communicate with the mesh network.","type":"text"},{"text":" ","type":"text"},{"text":"Always use the current IV Index of the mesh network.","type":"text"}]}],"type":"aside","name":"Important","style":"important"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkError\/ivIndexTooSmall","type":"reference"},{"type":"text","text":" when the new IV Index is"},{"type":"text","text":" "},{"type":"text","text":"lower than the current one."}]}],"type":"aside","style":"note","name":"Throws"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/m