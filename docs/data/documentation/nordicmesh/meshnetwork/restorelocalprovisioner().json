{"abstract":[{"text":"This method restores the local Provisioner to the one used previously","type":"text"},{"text":" ","type":"text"},{"text":"on this device.","type":"text"}],"variants":[{"paths":["\/documentation\/nordicmesh\/meshnetwork\/restorelocalprovisioner()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork\/restoreLocalProvisioner()"},"metadata":{"title":"restoreLocalProvisioner()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"restoreLocalProvisioner","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"method","externalID":"s:10NordicMesh0B7NetworkC23restoreLocalProvisionerSbyF","extendedModule":"NordicMesh","roleHeading":"Instance Method","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"restoreLocalProvisioner"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"True","type":"codeVoice"},{"text":", if the Provisioner has been restored, or","type":"text"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" when the network is new to this device.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If the network is new to this device this method returns ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"In that case a new Provisioner object should be created and set a local Provisioner.","type":"text"}]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"This library always uses the Provisioner at index 0"},{"type":"text","text":" "},{"type":"text","text":"as the local Provisioner. When this method returns"},{"type":"text","text":" "},{"type":"codeVoice","code":"false"},{"type":"text","text":" it does not mean, that there is no local Provisioner"},{"type":"text","text":" "},{"type":"text","text":"set, rather that restoring the old one has failed and"},{"type":"text","text":" "},{"type":"text","text":"the local Provisioner is set to the one that has already"},{"type":"text","text":" "},{"type":"text","text":"been at index 0."}],"type":"paragraph"}]}],"kind":"content"}],"references":{"doc://NordicMesh/documentation/NordicMesh/MeshNetwork":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MeshNetwork","kind":"identifier"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork","kind":"symbol","url":"\/documentation\/nordicmesh\/meshnetwork","title":"MeshNetwork","type":"topic","abstract":[{"text":"The Bluetooth Mesh Network configuration.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"MeshNetwork","kind":"identifier"}]},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/Me