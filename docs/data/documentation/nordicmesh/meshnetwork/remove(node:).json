{"abstract":[{"type":"text","text":"Removes the Node from the local database."}],"variants":[{"paths":["\/documentation\/nordicmesh\/meshnetwork\/remove(node:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork\/remove(node:)","interfaceLanguage":"swift"},"metadata":{"extendedModule":"NordicMesh","roleHeading":"Instance Method","externalID":"s:10NordicMesh0B7NetworkC6remove4nodeyAA4NodeC_tF","title":"remove(node:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"kind":"externalParam","text":"node"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10NordicMesh4NodeC","kind":"typeIdentifier","text":"Node"},{"kind":"text","text":")"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"method","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetwork"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"remove","kind":"identifier"},{"text":"(","kind":"text"},{"text":"node","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/Node","preciseIdentifier":"s:10NordicMesh4NodeC","text":"Node","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The Node to be removed.","type":"text"}],"type":"paragraph"}],"name":"node"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method only removes the Node from the local database, but the Node","type":"text"},{"text":" ","type":"text"