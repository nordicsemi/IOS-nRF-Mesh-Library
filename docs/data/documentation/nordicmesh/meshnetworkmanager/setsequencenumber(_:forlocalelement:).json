ts the next outgoing sequence number of the given Element on local Node.","type":"text"},{"text":" ","type":"text"},{"text":"This 24-bit number will be set in the next message sent by this Element. The sequence","type":"text"},{"text":" ","type":"text"},{"text":"number is increased by 1 every time the Element sends a message.","type":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/MeshNetworkManager\/setSequenceNumber(_:forLocalElement:)","kind":"symbol","url":"\/documentation\/nordicmesh\/meshnetworkmanager\/setsequencenumber(_:forlocalelement:)","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/Element":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/Element","type":"topic","abstract":[{"text":"An Element is an addressable entity within a ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/Node","isActive":true,"type":"reference"},{"text":".","type":"text"}],"url":"\/documentation\/nordicmesh\/element","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"identifier"}],"title":"Element","navigatorTitle":[{"text":"Element","kind":"identifier"}],"role":"symbol"}}}