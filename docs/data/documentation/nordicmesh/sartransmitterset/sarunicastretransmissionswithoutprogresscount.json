{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sarUnicastRetransmissionsWithoutProgressCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","text":"UInt8"}],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"The maximum number of transmissions of a segment without progress is","type":"text"},{"text":" ","type":"text"},{"text":"calculated using the formula:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["SAR Unicast Retransmissions Without Progress Count + 1"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"For example, "},{"code":"0b0000","type":"codeVoice"},{"text":" represents a single transmission, and ","type":"text"},{"code":"0b0111","type":"codeVoice"},{"text":" ","type":"text"},{"text":"represents 8 transmissions.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value of the "},{"inlineContent":[{"type":"text","text":"SAR Unicast Retransmissions Without Progress"},{"type":"text","text":" "},{"type":"text","text":"Count state"}],"type":"strong"},{"type":"text","text":" is "},{"code":"0b0010","type":"codeVoice"},{"type":"text","text":" (3 transmissions)."}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"The value of this state should be set to a value greater than the"},{"type":"text","text":" "},{"type":"text","text":"value of the "},{"inlineContent":[{"text":"SAR Acknowledgement Retransmissions Count","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"on a peer node. This helps prevent the SAR transmitter from"},{"type":"text","text":" "},{"type":"text","text":"abandoning the SAR prematurely."}],"type":"paragraph"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/SarTransmitterSet\/sarUnicastRetransmissionsWithoutProgressCount"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/sartransmitterset\/sarunicastretransmissionswithoutprogresscount"]}],"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/SarTransmitterSet"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"The ","type":"text"},{"inlineContent":[{"text":"SAR Unicast Retransmissions Without Progress Count state","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"text":"is a 4-bit value that controls the maximum number of transmissions of segments","type":"text"},{"text":" ","type":"text"},{"text":"of segmented messages to a Unicast destination without progress","type":"text"},{"text":" ","type":"text"},{"text":"(i.e., without newly marking any segment as acknowledged).","type":"text"}],"metadata":{"modules":[{"name":"NordicMesh"}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sarUnicastRetransmissionsWithoutProgressCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V","text":"UInt8"}],"roleHeading":"Instance Property","title":"sarUnicastRetransmissionsWithoutProgressCount","symbolKind":"property","role":"symbol","externalID":"s:10NordicMesh17SarTransmitterSetV45sarUnicastRetransmissionsWithoutProgressCounts5UInt8Vvp"},"sections":[],"references":{"doc://NordicMesh/documentation/NordicMesh/SarTransmitterSet/sarUnicastRetransmissionsWithoutProgressCount":{"type":"topic","title":"sarUnicastRetransmissionsWithoutProgressCount","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"sarUnicastRetransmissionsWithoutProgressCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier"