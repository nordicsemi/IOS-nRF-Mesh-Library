{"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLHueSetUnacknowledged\/delay","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLHueSetUnacknowledged"]]},"metadata":{"modules":[{"name":"NordicMesh"}],"externalID":"s:10NordicMesh28LightHSLHueSetUnacknowledgedV5delays5UInt8VSgvp","role":"symbol","title":"delay","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"roleHeading":"Instance Property","symbolKind":"property"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5UInt8V","text":"UInt8","kind":"typeIdentifier"},{"text":"?","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"text":"changes of successful delivery, such message can be repeated.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The first message could be sent with longer "},{"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"text":" ","type":"text"},{"type":"text","text":"synchronized."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This file has to be set together with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime"},{"text":".","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/nordicmesh\/lighthslhuesetunacknowledged\/delay"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"references":{"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"},"doc://NordicMesh/documentation/NordicMesh/LightHSLHueSetUnacknowledged/delay":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/lighthslhuesetunacknowledged\/delay","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLHueSetUnacknowledged\/delay","title":"delay",