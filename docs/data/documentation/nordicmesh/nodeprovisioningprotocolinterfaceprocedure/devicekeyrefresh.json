{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"deviceKeyRefresh"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The Device Key Refresh procedure does not transfer a device key to the"},{"type":"text","text":" "},{"type":"text","text":"device over the air; instead, it uses the provisioning protocol to"},{"type":"text","text":" "},{"type":"text","text":"compute the Device Key Candidate."}],"type":"paragraph"},{"inlineContent":[{"text":"The device key value change that results from this procedure is thus","type":"text"},{"text":" ","type":"text"},{"text":"performed at the same security level as is provisioning of the","type":"text"},{"text":" ","type":"text"},{"text":"unprovisioned device. The Unicast Address, Network Key, Network Key Index,","type":"text"},{"text":" ","type":"text"},{"text":"and IV Index are not affected by this procedure.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NodeProvisioningProtocolInterfaceProcedure\/deviceKeyRefresh"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/nodeprovisioningprotocolinterfaceprocedure\/devicekeyrefresh"]}],"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/NodeProvisioningProtocolInterfaceProcedure"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"The Device Key Refresh procedure is used to change the Device Key"},{"type":"text","text":" "},{"type":"text","text":"without reprovisioning a Node and without a need to reconfigure the Node."}],"metadata":{"symbolKind":"case","externalID":"s:10NordicMesh42NodeProvisioningProtocolInterfaceProcedureO16deviceKeyRefreshyA2CmF","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"deviceKeyRefresh","kind":"identifier"}],"title":"NodeProvisioningProtocolInterfaceProcedure.deviceKeyRefresh","modules":[{"name":"NordicMesh"}],"roleHeading":"Case"},"sections":[],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/NodeProvisioningProtocolInterfaceProcedure/deviceKeyRefresh":{"type":"topic","title":"NodeProvisioningProtocolInterfaceProcedure.deviceKeyRefresh","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"deviceKeyRefresh","kind":"identifier"}],"abstract":[{"text":"The Device Key Refresh procedure is used to change the Device Key","type":"text"},{"text":" ","type":"text"},{"text":"without reprovisioning a Node and without a need to reconfigure the Node.","type":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NodeProvisioningProtocolInterfaceProcedure\/deviceKeyRefresh","kind":"symbol","url":"\/documentation\/nordicmesh\/nodeprovisioningprotocolinterfaceprocedure\/devicekeyrefresh","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/NodeProvisioningProtocolInterfaceProcedure":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/NodeProvisioningProtocolInterfaceProcedure","type":"topic","abstract":[{"text":"The Node Provisioning Protocol Interface is an interface used by the Node","type":"text"},{"text":" ","type":"text"},{"text":"to route the Provisioning PDUs between the Provisioner and the layer that","type":"text"},{"text":" ","type":"text"},{"text":"is executing the provisioning protocol.","type":"text"}],"url":"\/documentation\/nordicmesh\/nodeprovisioningprotocolinterfaceprocedure","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NodeProvisioningProtocolInterfaceProcedure","kind":"identifier"}],"title":"NodeProvisioningProtocolInterfaceProcedure","navigatorTitle":[{"text":"NodeProvisioningProtocolInterfaceProcedure","kind":"identifier"}],"role":"symbol"}}}