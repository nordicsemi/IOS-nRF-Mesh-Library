{"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSet\/continueTransaction","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","modules":[{"name":"NordicMesh"}],"externalID":"s:10NordicMesh18TransactionMessagePAAE08continueC0Sbvp::SYNTHESIZED::s:10NordicMesh15GenericLevelSetV","symbolKind":"property","title":"continueTransaction","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Property","extendedModule":"NordicMesh"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSet"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The messages within a transaction carry the cumulative values of","type":"text"},{"text":" ","type":"text"},{"text":"a field. In case one or more messages within a transaction are not","type":"text"},{"text":" ","type":"text"},{"text":"received by the Server (e.g., as a result of radio collisions),","type":"text"},{"text":" ","type":"text"},{"text":"the next received message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This defaults to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", which means that each new message will","type":"text"},{"text":" ","type":"text"},{"text":"receive a new transaction identifier (if not set explicitly).","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/nordicmesh\/genericlevelset\/continuetransaction"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/GenericLevelSet":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"GenericLevelSet"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSet","kind":"symbol","url":"\/documentation\/nordicmesh\/genericlevelset","title":"GenericLevelSet","type":"topic","abstract":[],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"GenericLevelSet"}]},"doc://NordicMesh/documentation/NordicMesh/GenericLevelSet/continueTransaction":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericLevelSet\/continueTransaction","type":"topic","url":"\/documentation\/nordicmesh\/genericlevelset\/continuetransaction","abstract":[{"type":"text","text":"Whether the message should star