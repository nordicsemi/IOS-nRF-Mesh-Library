{"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/lighthslsetunacknowledged\/continuetransaction"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLSetUnacknowledged\/continueTransaction"},"metadata":{"title":"continueTransaction","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh18TransactionMessagePAAE08continueC0Sbvp::SYNTHESIZED::s:10NordicMesh25LightHSLSetUnacknowledgedV","extendedModule":"NordicMesh","roleHeading":"Instance Property","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLSetUnacknowledged"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The messages within a transaction carry the cumulative values of","type":"text"},{"text":" ","type":"text"},{"text":"a field. In case one or more messages within a transaction are not","type":"text"},{"text":" ","type":"text"},{"text":"received by the Server (e.g., as a result of radio collisions),","type":"text"},{"text":" ","type":"text"},{"text":"the next received message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This defaults to "},{"code":"false","type":"codeVoice"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}]}]}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/LightHSLSetUnacknowledged/continueTransaction":{"type":"topic","title":"continueTransaction","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLSetUnacknowledged\/continueTransaction","kind":"symbol","url":"\/documentation\/nordicmesh\/lighthslsetunacknowledged\/continuetransaction","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/LightHSLSetUnacknowledged":{"role":"symbol","kind"