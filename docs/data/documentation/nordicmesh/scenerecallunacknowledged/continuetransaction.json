{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The messages within a transaction carry the cumulative values of"},{"type":"text","text":" "},{"type":"text","text":"a field. In case one or more messages within a transaction are not"},{"type":"text","text":" "},{"type":"text","text":"received by the Server (e.g., as a result of radio collisions),"},{"type":"text","text":" "},{"type":"text","text":"the next received message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/SceneRecallUnacknowledged\/continueTransaction"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/n