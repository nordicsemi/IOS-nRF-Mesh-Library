"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"title":"delay"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/GenericOnOffSetUnacknowledged/delay":{"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericOnOffSetUnacknowledged\/delay","kind":"symbol","url":"\/documentation\/nordicmesh\/genericonoffsetunacknowledged\/delay","title":"delay","type":"topic","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"role":"symbol"}}}