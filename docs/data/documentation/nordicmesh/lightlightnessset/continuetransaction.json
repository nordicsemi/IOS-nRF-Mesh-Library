message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A new transaction is started when this field is set to "},{"type":"codeVoice","code":"true"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or when the last message of the transaction was sent 6 or"},{"type":"text","text":" "},{"type":"text","text":"more seconds earlier."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This defaults to "},{"code":"false","type":"codeVoice"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}]}],"kind":"content"}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightLightnessSet":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSet","navigatorTitle":[{"kind":"identifier","text":"LightLightnessSet"}],"role":"symbol","url":"\/documentation\/nordicmesh\/lightlightnessset","abstract":[],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightLightnessSet","kind":"identifier"}],"title":"LightLightnessSet","type":"topic"},"doc://NordicMesh/documentation/NordicMesh/LightLightnessSet/continueTransaction":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSet\/continueTransaction","role":"symbol","url":"\/documentation\/nordicmesh\/lightlightnessset\/continuetransaction","abstract":[{"text":"Whether the message should start a new transaction.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"title":"continueTransaction","type":"topic"},