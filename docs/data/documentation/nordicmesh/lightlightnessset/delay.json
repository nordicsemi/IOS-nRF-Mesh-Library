":"text"},{"text":" ","type":"text"},{"text":"The first message could be sent with longer ","type":"text"},{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and each following with a shorter one, so when different Nodes","type":"text"},{"text":" ","type":"text"},{"text":"receive different messages, the action they take seems more","type":"text"},{"text":" ","type":"text"},{"text":"synchronized.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This file has to be set together with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime"},{"type":"text","text":"."}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightLightnessSet/delay":{"type":"topic","title":"delay","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"abstract":[{"text":"Message execution delay in 5 millisecond steps.","type":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSet\/delay","kind":"symbol","url":"\/documentation\/nordicmesh\/lightlightnessset\/delay","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/LightLightnessSet":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSet","navigatorTitle":[{"kind":"identifier","text":"LightLightnessSet"}],"role":"symbol","url":"\/documentation\/nordicmesh\/lightlightnessset","abstract":[],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightLightnessSet","kind":"identifier"}],"title":"LightLightnessSet","type":"topic"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"s