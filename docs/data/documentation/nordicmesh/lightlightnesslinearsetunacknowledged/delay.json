{"metadata":{"externalID":"s:10NordicMesh37LightLightnessLinearSetUnacknowledgedV5delays5UInt8VSgvp","roleHeading":"Instance Property","symbolKind":"property","role":"symbol","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}],"title":"delay","modules":[{"name":"NordicMesh"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessLinearSetUnacknowledged\/delay"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessLinearSetUnacknowledged"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Message execution delay in 5 millisecond steps.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such message can be repeated."},{"type":"text","text":" "},{"type":"text","text":"