d message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}],"type":"paragraph"},{"inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", which means that each new message will"},{"type":"text","text":" "},{"type":"text","text":"receive a new transaction identifier (if not set explicitly)."}]}],"kind":"content"}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightHSLHueSet/continueTransaction":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLHueSet\/continueTransaction","role":"symbol","url":"\/documentation\/nordicmesh\/lighthslhueset\/continuetransaction","abstract":[{"text":"Whether the message should start a new transaction.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"title":"continueTransaction","type":"topic"},"doc://NordicMesh/documentation/NordicMesh/LightHSLHueSet":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/lighthslhueset","navigatorTitle":[{"text":"LightHSLHueSet","kind":"identifier"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLHueSet","title":"LightHSLHueSet","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightHSLHueSet","kind":"identifier"}],"type":"topic","abstract":[]},"doc://NordicMesh/documentation/NordicM