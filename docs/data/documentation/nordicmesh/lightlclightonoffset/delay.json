{"abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"variants":[{"paths":["\/documentation\/nordicmesh\/lightlclightonoffset\/delay"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLCLightOnOffSet\/delay"},"metadata":{"title":"delay","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":"?"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh20LightLCLightOnOffSetV5delays5UInt8VSgvp","roleHeading":"Instance Property","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLCLightOnOffSet"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":"?"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such messa