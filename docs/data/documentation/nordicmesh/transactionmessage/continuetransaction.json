 a transaction are not"},{"type":"text","text":" "},{"type":"text","text":"received by the Server (e.g., as a result of radio collisions),"},{"type":"text","text":" "},{"type":"text","text":"the next received message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}]},{"type":"paragraph","inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more seconds earlier."}]},{"inlineContent":[{"text":"This defaults to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", which means that each new message will","type":"text"},{"text":" ","type":"text"},{"text":"receive a new transaction identifier (if not set explicitly).","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransactionMessage":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TransactionMessage"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransactionMessage","kind":"symbol","url":"\/documentation\/nordicmesh\/transactionmessage","title":"TransactionMessage","type":"topic","abstract":[{"text":"A message with Transaction Identifier.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TransactionMessage"}]},"doc://NordicMesh/documentation/NordicMesh/TransactionMessage/contin