{"abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/transactionmessage\/continuetransaction-63j44"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransactionMessage\/continueTransaction-63j44"},"kind":"symbol","metadata":{"title":"continueTransaction","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"continueTransaction","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh18TransactionMessagePAAE08continueC0Sbvp","extendedModule":"NordicMesh","roleHeading":"Instance Property","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransactionMessage"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The messages within a transaction carry the cumulative values of"},{"type":"text","text":" "},{"type":"text","text":"a field. In case one or more messages within a transaction are not"},{"type":"text","text":" "},{"type":"text","text":"received by the Server (e.g., as a result of radio collisions),"},{"type":"text","text":" "},{"type":"text","text":"the next received message will make up for the lost messages,"},{"type":"text","text":" "},{"type":"text","text":"carrying cumulative values of the field."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A new transaction is started when this field is set to "},{"code":"true","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This defaults to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", which means that each new message will","type":"text"},{"text":" ","type":"text"},{"text":"receive a new transaction identifier (if not set explicitly).","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://NordicMesh/documentation/NordicMesh/TransactionMessage":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TransactionMessage"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransactionMessage","kind":"symbol","url":"\/documentation\/nordicmesh\/transactionmessage","title":"TransactionMessage","type":"topic","abstract":[{"text":"A message with Transaction Identifier.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TransactionMessage"}]},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransactionMessage/continueTransaction-63j44":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransactionMessage\/continueTransaction-63j44","role":"symbol","url":"\/documentation\/nordicmesh\/transactionmessage\/continuetransaction-63j44","abstract":[{"type":"text","text":"Whether the message should start a new transaction."}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"continueTransaction","type":"topic"}}}