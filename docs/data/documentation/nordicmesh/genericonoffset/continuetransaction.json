received message will make up for the lost messages,","type":"text"},{"text":" ","type":"text"},{"text":"carrying cumulative values of the field.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A new transaction is started when this field is set to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or when the last message of the transaction was sent 6 or","type":"text"},{"text":" ","type":"text"},{"text":"more seconds earlier.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This defaults to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", which means that each new message will","type":"text"},{"text":" ","type":"text"},{"text":"receive a new transaction identifier (if not set explicitly).","type":"text"}]}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/GenericOnOffSet":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/genericonoffset","navigatorTitle":[{"text":"GenericOnOffSet","kind":"identifier"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/GenericOnOffSet","title":"GenericOnOffSet","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GenericOnOffSet","kind":"identifier"}],"type":"topic","abstract":[]},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/GenericOnOffSet/continueTransaction":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"continueTransaction"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"identifier":"doc:\/\/NordicMesh\/d