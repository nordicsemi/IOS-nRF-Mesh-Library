es of successful delivery, such message can be repeated.","type":"text"},{"text":" ","type":"text"},{"text":"The first message could be sent with longer ","type":"text"},{"isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"reference"},{"text":" ","type":"text"},{"text":"and each following with a shorter one, so when different Nodes","type":"text"},{"text":" ","type":"text"},{"text":"receive different messages, the action they take seems more","type":"text"},{"text":" ","type":"text"},{"text":"synchronized.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This file has to be set together with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"reference"},{"text":".","type":"text"}]}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"title":"delay"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":t