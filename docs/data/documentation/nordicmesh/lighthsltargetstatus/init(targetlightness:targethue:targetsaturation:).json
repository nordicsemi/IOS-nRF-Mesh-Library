ation of a color light.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"0x0001 - 0xFFFE - the 16-bit value representing the saturation of a color light."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"0xFFFF - the highest perceived saturation of a light.","type":"text"}]}]}],"type":"unorderedList"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/LightHSLTargetStatus/init(targetLightness:targetHue:targetSaturation:)":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLTargetStatus\/init(targetLightness:targetHue:targetSaturation:)","type":"topic","abstract":[{"text":"Creates the Light HSL Target Status message.","type":"text"}],"url":"\/documentation\/nordicmesh\/lighthsltargetstatus\/init(targetlightness:targethue:targetsaturation:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"targetLightness"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt16","preciseIdentifier":"s:s6UInt16V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"targetHue"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt16","preciseIdentifier":"s:s6UInt16V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"targetSaturation"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt16","preciseIdentifier":"s:s6UInt16V"},{"kind":"text","text":")"}],"title":"init(targetLightness:targetHue:targetSaturation:)","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/LightHSLTargetStatus":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LightHSLTargetStatus"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightHSLTargetStatus","kind":"symbol","url":"\/documentation\/nordicmesh\/lighthsltargetstatus","title":"LightHSLTargetStatus","type":"topic","abstract":[],"role":"symbol","navigatorTitle":[{"kind":"id