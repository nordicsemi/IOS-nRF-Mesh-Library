{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLSet\/delay","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"NordicMesh"}],"role":"symbol","externalID":"s:10NordicMesh11LightCTLSetV5delays5UInt8VSgvp","title":"delay","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5UInt8V","text":"UInt8","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"roleHeading":"Instance Property","symbolKind":"property"},"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLSet"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier","text":"UInt8"},{"kind":"text","text":"?"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such message can be repeated."},{"type":"text","text":" "},{"type":"text","text":"The first message could be sent with longer "},{"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"type":"text","text":" "},{"type":"text","text":"synchronized."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This file has to be set together with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime"},{"type":"text","text":"."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/lightctlset\/delay"]}],"abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"},"doc://NordicMesh/documentation/NordicMesh/LightCTLSet/delay":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLSet\/delay","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctlset\/delay","title":"delay","type":"topic","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"role":"symbol"},"doc://NordicMesh/documentation/NordicMesh/LightCTLSet":{"type":"topic","title":"LightCTLSet","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightCTLSet","kind":"identifier"}],"abstract":[{"text":"Light CTL Set is an acknowledged message used to set the Light CTL Lightness state,","type":"text"},{"text":" ","type":"text"},{"text":"Light CTL Temperature state, and the Light CTL Delta UV state of an Element.","type":"text"}],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightCTLSet","kind":"symbol","url":"\/documentation\/nordicmesh\/lightctlset","role":"symbol","navigatorTitle":[{"text":"LightCTLSet","kind":"identifier"}]},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"title":"delay"}}}