{"abstract":[{"type":"text","text":"Time To Live (TTL) value used in a firmware image distribution."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/nordicmesh\/firmwaredistributionstart\/ttl"]}],"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStart\/ttl","interfaceLanguage":"swift"},"metadata":{"title":"ttl","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ttl","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"}],"modules":[{"name":"NordicMesh"}],"symbolKind":"property","externalID":"s:10NordicMesh25FirmwareDistributionStartV3ttls5UInt8Vvp","roleHeading":"Instance Property","role":"symbol"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStart"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ttl","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The TTL value is the maximum number of hops the message is allowed to go through."},{"type":"text","text":" "},{"type":"text","text":"Value 0 means, that messages won’t be relied and will only be processed by the Nodes"},{"type":"text","text":" "},{"type":"text","text":"that are in direct range or the connected GATT Proxy Node."}],"type":"paragraph"},{"inlineContent":[{"text":"Valid values are in the range 0…127 (","type":"text"},{"code":"0x00 - 0x7F","type":"codeVoice"},{"type":"text","text":"). Value 255 ("},{"type":"codeVoice","code":"0xFF"},{"type":"text","text":") means that"},{"type":"text","text":" "},{"type":"text","text":"the default TTL value is to be used. Other values are Prohibited."}],"type":"paragraph"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionStart":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStart","url":"\/documentation\/nordicmesh\/firmwaredistributionstart","type":"topic","abstract":[{"type":"text","text":"The Firmware Distribution Start message is an acknowledged message sent by"},{"type":"text","text":" "},{"type":"text","text":"a Firmware Distribution Client to start the firmware image distribution to the Target Nodes"},{"type":"text","text":" "},{"type":"text","text":"in the Distribution Receivers List."}],"navigatorTitle":[{"kind":"identifier","text":"FirmwareDistributionStart"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FirmwareDistributionStart"}],"title":"FirmwareDistributionStart"},"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionStart/ttl":{"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionStart\/ttl","type":"topic","url":"\/documentation\/nordicmesh\/firmwaredistributionstart\/ttl","abstract":[{"text":"Time To Live (TTL) value used in a firmware image distribution.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"ttl"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UInt8","preciseIdentifier":"s:s5UInt8V"}],"title":"ttl","role":"symbol"},"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"}}}