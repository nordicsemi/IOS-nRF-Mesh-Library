semi.com\/bundle\/ncs-latest\/page\/zephyr\/connectivity\/bluetooth\/api\/mesh\/dfu.html#firmware_effect","identifier":"https:\/\/docs.nordicsemi.com\/bundle\/ncs-latest\/page\/zephyr\/connectivity\/bluetooth\/api\/mesh\/dfu.html#firmware_effect"},"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionReceiversDeleteAll":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionReceiversDeleteAll","navigatorTitle":[{"text":"FirmwareDistributionReceiversDeleteAll","kind":"identifier"}],"role":"symbol","url":"\/documentation\/nordicmesh\/firmwaredistributionreceiversdeleteall","abstract":[{"type":"text","text":"The Firmware Distribution Receivers Delete All message is an acknowledged message sent by"},{"type":"text","text":" "},{"type":"text","text":"a Firmware Distribution Client to remove all entries from the Distribution Receivers List state of"},{"type":"text","text":" "},{"type":"text","text":"a Firmware Distribution Server."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FirmwareDistributionReceiversDeleteAll","kind":"identifier"}],"title":"FirmwareDistributionReceiversDeleteAll","type":"topic"},"doc://NordicMesh/documentation/NordicMesh/Connecting":{"kind":"article","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/Connecting","url":"\/documentation\/nordicmesh\/connecting","type":"topic","abstract":[{"text":"How to connect to the network via GATT Proxy node.","type":"text"}],"role":"article","title":"Connecting to mesh network"},"https://docs.nordicsemi.com/bundle/ncs-latest/page/zephyr/services/device_mgmt/smp_transport.html":{"title":"SMP Service","url":"https:\/\/docs.nordicsemi.com\/bundle\/ncs-latest\/page\/zephyr\/services\/device_mgmt\/smp_transport.html","type":"link","identifier":"https:\/\/docs.nordicsemi.com\/bundle\/ncs-latest\/page\/zephyr\/services\/device_mgmt\/smp_transport.html","titleInlineContent":[{"type":"text","text":"SMP Service"}]},"https://github.com/nordicsemi/IOS-nRF-Mesh-Library/blob/main/Example/Source/View%20Controllers/Network/DFU/DFUViewController.swift":{"url":"https:\/\/github.com\/nordicsemi\/IOS-nRF-Mesh-Library\/blob\/main\/Example\/Source\/View%20Controllers\/Network\/DFU\/DFUViewController.swift","identifier":"https:\/\/github.com\/nordicsemi\/IOS-nRF-Mesh-Library\/blob\/main\/Example\/Source\/View%20Controllers\/Network\/DFU\/DFUViewController.swift","type":"link","titleInlineContent":[{"type":"codeVoice","code":"DFUViewController"}],"title":"DFUViewController"},"https://www.bluetooth.com/specifications/specs/mesh-device-firmware-update-model/":{"title":"Mesh Device Firmware Update Model v1.0","url":"https:\/\/www.bluetooth.com\/specifications\/specs\/mesh-device-firmware-update-model\/","type":"link","titleInlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Mesh Device Firmware Update Model v1.0"}]}],"identifier":"https:\/\/www.bluetooth.com\/specifications\/specs\/mesh-device-firmware-update-model\/"},"doc://NordicMesh/documentation/NordicMesh/FirmwareUpdateFirmwareMetadataStatus/additionalInformation":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareUpdateFirmwareMetadataStatus\/additionalInformation","role":"symbol","url":"\/documentation\/nordicmesh\/firmwareupdatefirmwaremetadatastatus\/additionalinformation","abstract":[{"type":"text","text":"The Firmware Update Additional Information state from the Firmware Update Server."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"additionalInformation","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10NordicMesh35FirmwareUpdateAdditionalInformationO","text":"FirmwareUpdateAdditionalInformation","kind":"typeIdentifier"}],"title":"additionalInformation","type":"topic"},"doc://NordicMesh/documentation/NordicMesh/FirmwareDistributionApply":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/FirmwareDistributionApply","type":"topic","url":"\/documentation\/nordicmesh\/firmwaredistributionapply","abstract":[{"type":"text","text":"The Firmware Distribution Apply message is an acknowledged message sent from"},{"type":"text","text":" "},{"type":"text","text":"a Firmware Distribution Client to a Firmware Distribution Server to apply the firmware"},{"type":"text","text":" "},{"type":"text","text":"image on the Target Nodes."}],"navigatorTitle":[{"text":"FirmwareDistributionApply","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FirmwareDistributionApply","kind":"identifier"}],"title":"FirmwareDistributionApply"},"doc://NordicMesh/documentation/NordicMesh/ProvisioningDevices":{"kind":"article","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/ProvisioningDevices","role":"article","url":"\/documentation\/nordicmesh\/provisioningdevices","abstract":[{"text":"Provisioning is the process of adding an unprovisioned device to a mesh network in a secure way.","type":"text"}],"title":"Provisioning","type":"topic"}}}