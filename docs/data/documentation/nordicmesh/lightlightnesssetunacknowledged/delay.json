{"hierarchy":{"paths":[["doc:\/\/NordicMesh\/documentation\/NordicMesh","doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSetUnacknowledged"]]},"identifier":{"url":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSetUnacknowledged\/delay","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Property","externalID":"s:10NordicMesh31LightLightnessSetUnacknowledgedV5delays5UInt8VSgvp","title":"delay","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5UInt8V","text":"UInt8","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"symbolKind":"property","modules":[{"name":"NordicMesh"}],"role":"symbol"},"sections":[],"abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The purpose of this field is to synchronize transitions initiated"},{"type":"text","text":" "},{"type":"text","text":"by sending the same message multiple times with a short delay."},{"type":"text","text":" "},{"type":"text","text":"For example, a Node would want to send a Generic On Off Set"},{"type":"text","text":" "},{"type":"text","text":"Unacknowledged message to a Group Address. In order to increase"},{"type":"text","text":" "},{"type":"text","text":"changes of successful delivery, such message can be repeated."},{"type":"text","text":" "},{"type":"text","text":"The first message could be sent with longer "},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay"},{"type":"text","text":" "},{"type":"text","text":"and each following with a shorter one, so when different Nodes"},{"type":"text","text":" "},{"type":"text","text":"receive different messages, the action they take seems more"},{"type":"text","text":" "},{"type":"text","text":"synchronized."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This file has to be set together with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/nordicmesh\/lightlightnesssetunacknowledged\/delay"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://NordicMesh/documentation/NordicMesh":{"abstract":[{"text":"Provision, configure and control Bluetooth mesh devices with nRF Mesh library.","type":"text"}],"type":"topic","kind":"symbol","role":"collection","title":"NordicMesh","url":"\/documentation\/nordicmesh","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh"},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/transitionTime":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/transitionTime","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/transitiontime","abstract":[{"type":"text","text":"The Transition Time field identifies the time that an Element will"},{"type":"text","text":" "},{"type":"text","text":"take to transition to the target state from the present state."}],"required":true,"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"transitionTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TransitionTime","preciseIdentifier":"s:10NordicMesh14TransitionTimeV"},{"kind":"text","text":"?"}],"title":"transitionTime"},"doc://NordicMesh/documentation/NordicMesh/LightLightnessSetUnacknowledged/delay":{"role":"symbol","kind":"symbol","url":"\/documentation\/nordicmesh\/lightlightnesssetunacknowledged\/delay","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSetUnacknowledged\/delay","title":"delay","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"delay"},{"kind":"text","text":": "},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":"?","kind":"text"}],"type":"topic","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}]},"doc://NordicMesh/documentation/NordicMesh/LightLightnessSetUnacknowledged":{"type":"topic","title":"LightLightnessSetUnacknowledged","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightLightnessSetUnacknowledged","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/LightLightnessSetUnacknowledged","kind":"symbol","url":"\/documentation\/nordicmesh\/lightlightnesssetunacknowledged","role":"symbol","navigatorTitle":[{"text":"LightLightnessSetUnacknowledged","kind":"identifier"}]},"doc://NordicMesh/documentation/NordicMesh/TransitionMessage/delay":{"kind":"symbol","identifier":"doc:\/\/NordicMesh\/documentation\/NordicMesh\/TransitionMessage\/delay","type":"topic","url":"\/documentation\/nordicmesh\/transitionmessage\/delay","abstract":[{"type":"text","text":"Message execution delay in 5 millisecond steps."}],"required":true,"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"delay","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UInt8","preciseIdentifier":"s:s5UInt8V","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"title":"delay"}}}